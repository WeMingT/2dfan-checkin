# === 必需 ===
SESSION_MAP={"用户ID":"cookie值"}

# === 签到模式（可选，默认 browser） ===
# browser: 本地浏览器自动化（免费）
# flaresolverr: FlareSolverr + WARP（免费，适合 VPS）
# api: 验证码服务（付费）
CHECKIN_MODE=browser

# === FlareSolverr 模式配置 ===
# FLARESOLVERR_URL=http://VPS_IP:8191/v1
# WARP_PROXY=socks5://127.0.0.1:40000
# WARP_PUBLIC_PROXY=socks5://your.vps.ip:40000
# WARP_PROXY_PROBE_TIMEOUT=3
# WARP_REMOTE_PROXY=socks5://deprecated.example.com:40000  # 已弃用，仅向后兼容

# === API 模式配置 ===
# CAPTCHA_PROVIDER=ezcaptcha
# EZCAPTCHA_CLIENT_KEY=your_api_key
# YESCAPTCHA_CLIENT_KEY=your_api_key
# YESCAPTCHA_USE_CN=false

# === 浏览器配置（可选） ===
# HEADLESS=false
# CHROME_VERSION=144
# HTTP_PROXY=http://proxy:port

# === 邮件通知（可选） ===
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your@qq.com
# SMTP_PASS=smtp授权码
# NOTIFY_EMAIL=receive@email.com
